@page "/song-generator"
@using VSCodeDevDaysDemo.Models
@using VSCodeDevDaysDemo.Services
@using Microsoft.AspNetCore.Components.Web
@inject ISongGeneratorService SongGeneratorService
@inject NavigationManager NavigationManager

<PageTitle>Crear Canción - Paso 1: Elige una Ocasión</PageTitle>

<div class="container my-4">
    <div class="progress mb-4">
        <div class="progress-bar" role="progressbar" style="width: 20%" aria-valuenow="20" aria-valuemin="0" aria-valuemax="100">Paso 1 de 5</div>
    </div>

    <h1 class="mb-4">¿Para qué ocasión deseas crear tu canción?</h1>
    
    <p class="lead mb-4">Selecciona el motivo para el cual estás creando esta canción personalizada. Esto nos ayudará a entender mejor el contexto y las emociones que deseas transmitir.</p>

    <div class="row g-4">
        @foreach (var occasion in Enum.GetValues<SongOccasion>())
        {
            <div class="col-md-4 col-sm-6 mb-4">
                <div class="card h-100 @(selectedOccasion == occasion ? "border-primary" : "")" 
                     @onclick="() => SelectOccasion(occasion)"
                     style="cursor: pointer;">
                    <div class="card-body text-center">
                        <i class="@GetOccasionIcon(occasion) fs-1 mb-3 @GetOccasionColor(occasion)"></i>
                        <h4>@GetOccasionName(occasion)</h4>
                        <p class="text-muted">@GetOccasionDescription(occasion)</p>
                        @if (selectedOccasion == occasion)
                        {
                            <div class="position-absolute top-0 end-0 p-2">
                                <i class="bi bi-check-circle-fill text-primary fs-4"></i>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-between mt-4">
        <button class="btn btn-outline-secondary" disabled>Atrás</button>
        <button class="btn btn-primary @(selectedOccasion == null ? "disabled" : "")" @onclick="ContinueToNextStep">
            Continuar <i class="bi bi-arrow-right"></i>
        </button>
    </div>
</div>

@code {
    private SongOccasion? selectedOccasion;
    private SongRequest songRequest = new SongRequest();

    private void SelectOccasion(SongOccasion occasion)
    {
        selectedOccasion = occasion;
        songRequest.Occasion = occasion;
    }

    private void ContinueToNextStep()
    {
        if (selectedOccasion != null)
        {
            // Store the song request in a service or session state in a real app
            // For now we'll just navigate to the next step with parameters
            NavigationManager.NavigateTo($"/song-generator/genre?occasion={selectedOccasion}");
        }
    }

    private string GetOccasionName(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "Cumpleaños",
        SongOccasion.Anniversary => "Aniversario",
        SongOccasion.Wedding => "Boda",
        SongOccasion.Proposal => "Propuesta",
        SongOccasion.Friendship => "Amistad",
        SongOccasion.FamilyCelebration => "Celebración Familiar",
        SongOccasion.Graduation => "Graduación",
        SongOccasion.NewBaby => "Nuevo Bebé",
        SongOccasion.Memorial => "Memorial",
        SongOccasion.Holiday => "Festividad",
        SongOccasion.Corporate => "Corporativo",
        SongOccasion.Other => "Otra Ocasión",
        _ => occasion.ToString()
    };

    private string GetOccasionDescription(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "Celebra un cumpleaños con una canción única.",
        SongOccasion.Anniversary => "Conmemora años de amor y compañía.",
        SongOccasion.Wedding => "El regalo perfecto para una boda inolvidable.",
        SongOccasion.Proposal => "Sorprende con una propuesta musical única.",
        SongOccasion.Friendship => "Celebra una amistad especial.",
        SongOccasion.FamilyCelebration => "Para reuniones y momentos familiares.",
        SongOccasion.Graduation => "Marca este logro académico importante.",
        SongOccasion.NewBaby => "Da la bienvenida a un nuevo miembro de la familia.",
        SongOccasion.Memorial => "Honra la memoria de un ser querido.",
        SongOccasion.Holiday => "Para celebraciones y fechas festivas.",
        SongOccasion.Corporate => "Eventos empresariales y reconocimientos.",
        SongOccasion.Other => "Cualquier otra ocasión especial.",
        _ => "Selecciona para continuar."
    };

    private string GetOccasionIcon(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "bi bi-cake",
        SongOccasion.Anniversary => "bi bi-balloon-heart",
        SongOccasion.Wedding => "bi bi-ring",
        SongOccasion.Proposal => "bi bi-envelope-heart",
        SongOccasion.Friendship => "bi bi-people",
        SongOccasion.FamilyCelebration => "bi bi-house-heart",
        SongOccasion.Graduation => "bi bi-mortarboard",
        SongOccasion.NewBaby => "bi bi-baby-carriage",
        SongOccasion.Memorial => "bi bi-flower1",
        SongOccasion.Holiday => "bi bi-calendar-event",
        SongOccasion.Corporate => "bi bi-building",
        SongOccasion.Other => "bi bi-stars",
        _ => "bi bi-question-circle"
    };

    private string GetOccasionColor(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "text-danger",
        SongOccasion.Anniversary => "text-primary",
        SongOccasion.Wedding => "text-success",
        SongOccasion.Proposal => "text-danger",
        SongOccasion.Friendship => "text-warning",
        SongOccasion.FamilyCelebration => "text-success",
        SongOccasion.Graduation => "text-info",
        SongOccasion.NewBaby => "text-pink",
        SongOccasion.Memorial => "text-secondary",
        SongOccasion.Holiday => "text-danger",
        SongOccasion.Corporate => "text-primary",
        SongOccasion.Other => "text-purple",
        _ => "text-muted"
    };
}