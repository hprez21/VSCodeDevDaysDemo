@page "/my-songs"
@using VSCodeDevDaysDemo.Models
@using VSCodeDevDaysDemo.Services
@using Microsoft.AspNetCore.Components.Web
@inject ISongGeneratorService SongGeneratorService
@inject NavigationManager NavigationManager

<PageTitle>Mis Canciones - Canciones Personalizadas</PageTitle>

<div class="container my-5">
    <h1 class="mb-4">Mis Canciones</h1>
    
    <p class="lead mb-5">
        Aquí puedes ver el estado de tus solicitudes de canciones personalizadas y descargar tus canciones una vez estén listas.
    </p>
    
    @if (songRequests == null || songRequests.Count == 0)
    {
        <div class="text-center py-5">
            <div class="mb-4">
                <i class="bi bi-music-note-list display-1 text-muted"></i>
            </div>
            <h3 class="mb-3">Aún no tienes canciones</h3>
            <p class="lead mb-4">Parece que todavía no has creado ninguna canción personalizada.</p>
            <a href="/song-generator" class="btn btn-primary btn-lg">Crear Mi Primera Canción</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-9">
                <div class="card">
                    <div class="card-header bg-light">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">Mis Solicitudes</h5>
                            <div class="btn-group">
                                <button type="button" class="btn btn-sm btn-outline-secondary">Todas</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary">En Proceso</button>
                                <button type="button" class="btn btn-sm btn-outline-secondary">Completadas</button>
                            </div>
                        </div>
                    </div>
                    <div class="list-group list-group-flush">
                        @foreach (var request in songRequests)
                        {
                            <div class="list-group-item">
                                <div class="d-flex w-100 justify-content-between align-items-center">
                                    <div>
                                        <h5 class="mb-1">
                                            @(string.IsNullOrEmpty(request.Title) ? $"Canción #{request.Id}" : request.Title)
                                        </h5>
                                        <p class="mb-1 text-muted">
                                            Solicitud #@request.Id.ToString("D6") | @request.RequestDate.ToString("dd/MM/yyyy")
                                        </p>
                                        <div class="d-flex align-items-center mt-2">
                                            <span class="badge bg-primary me-2">@GetGenreName(request.GenreId)</span>
                                            <span class="badge bg-info me-2">@GetOccasionName(request.Occasion)</span>
                                            <span class="badge bg-secondary">@GetPackageName(request.Package)</span>
                                        </div>
                                    </div>
                                    <div class="text-end">
                                        <div class="mb-2">
                                            @{
                                                var (statusClass, statusText) = GetStatusInfo(request.Stage);
                                            }
                                            <span class="badge @statusClass">@statusText</span>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => ViewSongDetails(request.Id)">
                                            Ver Detalles
                                        </button>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-lg-3">
                <div class="card">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Estadísticas</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span>Total de Canciones</span>
                                <span class="fw-bold">@songRequests.Count</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span>En Proceso</span>
                                <span class="fw-bold">@songRequests.Count(r => r.Stage != SongProductionStage.Ready && r.Stage != SongProductionStage.Delivered)</span>
                            </div>
                            <div class="d-flex justify-content-between mb-1">
                                <span>Completadas</span>
                                <span class="fw-bold">@songRequests.Count(r => r.Stage == SongProductionStage.Ready || r.Stage == SongProductionStage.Delivered)</span>
                            </div>
                        </div>
                        <div>
                            <a href="/song-generator" class="btn btn-primary w-100">
                                <i class="bi bi-plus-circle me-2"></i> Nueva Canción
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<SongRequest> songRequests = new();
    private Dictionary<int, string> genreNames = new();

    protected override async Task OnInitializedAsync()
    {
        // In a real app, we would get the user ID from authentication
        string userId = "demo-user";
        
        try
        {
            // Get all genres to display their names
            var genres = await SongGeneratorService.GetGenresAsync();
            foreach (var genre in genres)
            {
                genreNames[genre.Id] = genre.Name;
            }
            
            // Get song requests for the user
            songRequests = await SongGeneratorService.GetUserSongRequestsAsync(userId);
            
            // If we don't have any requests yet, let's create a demo request
            if (songRequests.Count == 0 && !string.IsNullOrEmpty(userId))
            {
                // Create a demo request to show the UI with some data
                var demoRequest = new SongRequest
                {
                    Title = "Nuestro Amor Eterno",
                    GenreId = 1, // Pop
                    Occasion = SongOccasion.Anniversary,
                    Tone = SongTone.Romantic,
                    StoryDetails = "Una canción para celebrar 10 años de matrimonio. Nos conocimos en la universidad y hemos pasado por muchos momentos juntos.",
                    RequestDate = DateTime.Now.AddDays(-5),
                    Stage = SongProductionStage.LyricsDrafted,
                    UserId = userId,
                    Package = SongDeliveryPackage.Premium
                };
                
                await SongGeneratorService.CreateSongRequestAsync(demoRequest);
                
                // Refresh the list
                songRequests = await SongGeneratorService.GetUserSongRequestsAsync(userId);
            }
        }
        catch (Exception)
        {
            // Handle error
        }
    }

    private void ViewSongDetails(int requestId)
    {
        // Navigate to a details page for this song request
        // In a real app, this would show more details, allow reviewing lyrics, etc.
        NavigationManager.NavigateTo($"/song-details/{requestId}");
    }

    private string GetGenreName(int genreId)
    {
        return genreNames.ContainsKey(genreId) ? genreNames[genreId] : "Género desconocido";
    }

    private string GetOccasionName(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "Cumpleaños",
        SongOccasion.Anniversary => "Aniversario",
        SongOccasion.Wedding => "Boda",
        SongOccasion.Proposal => "Propuesta",
        SongOccasion.Friendship => "Amistad",
        SongOccasion.FamilyCelebration => "Celebración Familiar",
        SongOccasion.Graduation => "Graduación",
        SongOccasion.NewBaby => "Nuevo Bebé",
        SongOccasion.Memorial => "Memorial",
        SongOccasion.Holiday => "Festividad",
        SongOccasion.Corporate => "Corporativo",
        SongOccasion.Other => "Otra Ocasión",
        _ => occasion.ToString()
    };

    private string GetPackageName(SongDeliveryPackage package) => package switch
    {
        SongDeliveryPackage.Basic => "Básico",
        SongDeliveryPackage.Premium => "Premium",
        SongDeliveryPackage.Deluxe => "Deluxe",
        _ => "Desconocido"
    };

    private (string cssClass, string text) GetStatusInfo(SongProductionStage stage) => stage switch
    {
        SongProductionStage.Requested => ("bg-secondary", "Solicitud Recibida"),
        SongProductionStage.LyricsDrafted => ("bg-info", "Letra en Revisión"),
        SongProductionStage.LyricsReviewed => ("bg-info", "Letra Aprobada"),
        SongProductionStage.InProduction => ("bg-warning", "En Producción"),
        SongProductionStage.MixingMastering => ("bg-warning", "Mezclando y Masterizando"),
        SongProductionStage.Ready => ("bg-success", "Lista para Descargar"),
        SongProductionStage.Delivered => ("bg-success", "Entregada"),
        _ => ("bg-secondary", "Estado Desconocido")
    };
}