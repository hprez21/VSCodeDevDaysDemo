@page "/song-generator/confirmation"
@using VSCodeDevDaysDemo.Models
@using VSCodeDevDaysDemo.Services
@using Microsoft.AspNetCore.Components.Web
@inject ISongGeneratorService SongGeneratorService
@inject NavigationManager NavigationManager

<PageTitle>¡Solicitud Completada! - Canciones Personalizadas</PageTitle>

<div class="container my-5">
    @if (songRequest == null)
    {
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p>Cargando información de tu solicitud...</p>
        </div>
    }
    else
    {
        <div class="text-center mb-5">
            <div class="display-1 text-success mb-4">
                <i class="bi bi-check-circle"></i>
            </div>
            <h1 class="display-5 fw-bold mb-3">¡Gracias por tu solicitud!</h1>
            <p class="lead">
                Hemos recibido correctamente la información para crear tu canción personalizada.
                Nuestro equipo creativo comenzará a trabajar en ella de inmediato.
            </p>
        </div>

        <div class="row">
            <div class="col-md-8 offset-md-2">
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h4 class="mb-0">Resumen de tu Solicitud</h4>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Número de Solicitud:</strong>
                            </div>
                            <div class="col-md-6">
                                #@songRequest.Id.ToString("D6")
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Fecha de Solicitud:</strong>
                            </div>
                            <div class="col-md-6">
                                @songRequest.RequestDate.ToString("dd/MM/yyyy HH:mm")
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Ocasión:</strong>
                            </div>
                            <div class="col-md-6">
                                @GetOccasionName(songRequest.Occasion)
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Género Musical:</strong>
                            </div>
                            <div class="col-md-6">
                                @(genre?.Name ?? "Género no disponible")
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Tono Emocional:</strong>
                            </div>
                            <div class="col-md-6">
                                @GetToneName(songRequest.Tone)
                            </div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <strong>Paquete Seleccionado:</strong>
                            </div>
                            <div class="col-md-6 fw-bold">
                                @GetPackageName(songRequest.Package)
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-light">
                        <h5 class="mb-0">Próximos Pasos</h5>
                    </div>
                    <div class="card-body">
                        <div class="timeline">
                            <div class="timeline-item">
                                <div class="timeline-marker bg-success">
                                    <i class="bi bi-check"></i>
                                </div>
                                <div class="timeline-content">
                                    <h5>Solicitud Recibida</h5>
                                    <p>Hemos registrado tu solicitud correctamente.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-marker @(songRequest.Stage >= SongProductionStage.LyricsDrafted ? "bg-success" : "bg-light")">
                                    @if (songRequest.Stage >= SongProductionStage.LyricsDrafted)
                                    {
                                        <i class="bi bi-check"></i>
                                    }
                                    else
                                    {
                                        <span>2</span>
                                    }
                                </div>
                                <div class="timeline-content">
                                    <h5>Creación de Letra</h5>
                                    <p>Nuestro equipo creativo está trabajando en la letra de tu canción. Estimado: 3-5 días.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-marker bg-light">
                                    <span>3</span>
                                </div>
                                <div class="timeline-content">
                                    <h5>Revisión de Letra</h5>
                                    <p>Te enviaremos un borrador de la letra para tu aprobación.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-marker bg-light">
                                    <span>4</span>
                                </div>
                                <div class="timeline-content">
                                    <h5>Producción Musical</h5>
                                    <p>Producción profesional de la canción. Estimado: 7-10 días.</p>
                                </div>
                            </div>
                            <div class="timeline-item">
                                <div class="timeline-marker bg-light">
                                    <span>5</span>
                                </div>
                                <div class="timeline-content">
                                    <h5>Entrega Final</h5>
                                    <p>¡Tu canción personalizada lista para disfrutar!</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-center mt-5">
                    <a href="/" class="btn btn-primary">Volver al Inicio</a>
                    <a href="/my-songs" class="btn btn-outline-primary ms-3">Ver Mis Canciones</a>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .timeline {
        position: relative;
        padding-left: 30px;
    }
    .timeline-item {
        position: relative;
        padding-bottom: 1.5rem;
    }
    .timeline-item:last-child {
        padding-bottom: 0;
    }
    .timeline-marker {
        position: absolute;
        left: -30px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 12px;
    }
    .timeline-item:not(:last-child)::after {
        content: "";
        position: absolute;
        left: -20px;
        top: 20px;
        height: calc(100% - 20px);
        width: 1px;
        background-color: #e0e0e0;
    }
</style>

@code {
    [Parameter]
    [SupplyParameterFromQuery]
    public int? RequestId { get; set; }

    private SongRequest? songRequest;
    private Genre? genre;

    protected override async Task OnInitializedAsync()
    {
        // Verify that we have a request ID, if not redirect back
        if (RequestId == null)
        {
            NavigationManager.NavigateTo("/song-generator");
            return;
        }

        try 
        {
            // Get the song request
            songRequest = await SongGeneratorService.GetSongRequestByIdAsync(RequestId.Value);
            
            // Get the genre information
            if (songRequest != null)
            {
                genre = await SongGeneratorService.GetGenreByIdAsync(songRequest.GenreId);
                
                // Update the song request to "LyricsDrafted" stage to simulate progress
                await SongGeneratorService.UpdateSongStageAsync(songRequest.Id, SongProductionStage.Requested);
            }
        }
        catch
        {
            // If request not found, go back to the start
            NavigationManager.NavigateTo("/song-generator");
        }
    }

    private string GetOccasionName(SongOccasion occasion) => occasion switch
    {
        SongOccasion.Birthday => "Cumpleaños",
        SongOccasion.Anniversary => "Aniversario",
        SongOccasion.Wedding => "Boda",
        SongOccasion.Proposal => "Propuesta",
        SongOccasion.Friendship => "Amistad",
        SongOccasion.FamilyCelebration => "Celebración Familiar",
        SongOccasion.Graduation => "Graduación",
        SongOccasion.NewBaby => "Nuevo Bebé",
        SongOccasion.Memorial => "Memorial",
        SongOccasion.Holiday => "Festividad",
        SongOccasion.Corporate => "Corporativo",
        SongOccasion.Other => "Otra Ocasión",
        _ => occasion.ToString()
    };

    private string GetToneName(SongTone tone) => tone switch
    {
        SongTone.Romantic => "Romántico",
        SongTone.Joyful => "Alegre",
        SongTone.Nostalgic => "Nostálgico",
        SongTone.Inspirational => "Inspirador",
        SongTone.Humorous => "Humorístico",
        SongTone.Emotional => "Emotivo",
        SongTone.Energetic => "Enérgico",
        SongTone.Reflective => "Reflexivo",
        SongTone.Hopeful => "Esperanzador",
        SongTone.Serious => "Serio",
        _ => tone.ToString()
    };

    private string GetPackageName(SongDeliveryPackage package) => package switch
    {
        SongDeliveryPackage.Basic => "Básico ($199.99)",
        SongDeliveryPackage.Premium => "Premium ($299.99)",
        SongDeliveryPackage.Deluxe => "Deluxe ($499.99)",
        _ => "Desconocido"
    };
}